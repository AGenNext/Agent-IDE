{
  "name": "agent-ide",
  "private": true,
  "workspaces": [
    "applications/*",
    "extensions/*",
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A --topological run build",
    "start": "yarn workspace @agennext/browser-app start",
    "lint": "eslint 'extensions/*/src/**/*.{ts,tsx}' 'packages/*/src/**/*.{ts,tsx}'",
    "typecheck": "yarn workspaces foreach -A run typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  }
}
