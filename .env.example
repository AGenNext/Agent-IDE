# Copy to .env and fill in your keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
BRAVE_API_KEY=

# Optional: local LLM via Ollama/vLLM
OLLAMA_BASE_URL=

# Optional: OpenHandS integration
OPENHANDS_URL=

# Set to true to enforce JWT auth
AUTH_ENABLED=false

# Set to true to allow shell tool
ALLOW_SHELL=false
