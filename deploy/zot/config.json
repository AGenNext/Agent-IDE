{
  "distSpecVersion": "1.1.0",
  "storage": {
    "rootDirectory": "/var/lib/zot",
    "gc": true,
    "gcDelay": "1h",
    "gcInterval": "24h",
    "dedupe": true,
    "commit": true
  },
  "http": {
    "address": "0.0.0.0",
    "port": "5000",
    "tls": {
      "cert": "/etc/zot/tls/tls.crt",
      "key":  "/etc/zot/tls/tls.key"
    }
  },
  "log": {
    "level":  "info",
    "output": "stdout"
  },
  "extensions": {
    "search": {
      "enable": true,
      "cve": {
        "updateInterval": "24h"
      }
    },
    "ui": {
      "enable": true
    },
    "metrics": {
      "enable":  true,
      "prometheus": {
        "path": "/metrics"
      }
    },
    "scrub": {
      "enable":   true,
      "interval": "24h"
    },
    "trust": {
      "enable":   true,
      "cosign":   true,
      "notation": true
    },
    "sync": {
      "enable":   false
    }
  },
  "accessControl": {
    "htpasswd": {
      "path": "/etc/zot/htpasswd"
    },
    "adminPolicy": {
      "users":   ["$ZOT_ADMIN_USER"],
      "actions": ["read", "create", "update", "delete"]
    },
    "repositories": {
      "**": {
        "defaultPolicy": ["read"],
        "policies": [
          {
            "users":   ["autonomyx-builder"],
            "actions": ["read", "create", "update"]
          },
          {
            "users":   ["autonomyx-deployer"],
            "actions": ["read"]
          }
        ]
      }
    }
  }
}
