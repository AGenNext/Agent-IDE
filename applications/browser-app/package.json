{
  "name": "@agennext/browser-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "theia build --mode development",
    "build:prod": "theia build",
    "start": "theia start --port 3000",
    "typecheck": "tsc --noEmit"
  },
  "theia": {
    "target": "browser",
    "frontend": {
      "config": {
        "applicationName": "Agent IDE",
        "defaultTheme": "dark",
        "defaultIconTheme": "vs-seti"
      }
    },
    "backend": {
      "config": {
        "startupTimeout": -1
      }
    }
  },
  "dependencies": {
    "@agennext/agent-ide-core": "^0.1.0",
    "@theia/core": "^1.44.0",
    "@theia/editor": "^1.44.0",
    "@theia/editor-preview": "^1.44.0",
    "@theia/filesystem": "^1.44.0",
    "@theia/markers": "^1.44.0",
    "@theia/monaco": "^1.44.0",
    "@theia/navigator": "^1.44.0",
    "@theia/outline-view": "^1.44.0",
    "@theia/preferences": "^1.44.0",
    "@theia/scm": "^1.44.0",
    "@theia/search-in-workspace": "^1.44.0",
    "@theia/terminal": "^1.44.0",
    "@theia/workspace": "^1.44.0"
  },
  "devDependencies": {
    "@theia/cli": "^1.44.0"
  }
}
