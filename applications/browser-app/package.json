{
  "name": "@agennext/browser-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "theia build --mode development",
    "build:prod": "theia build",
    "start": "theia start --port 3000",
    "typecheck": "tsc --noEmit"
  },
  "theia": {
    "target": "browser",
    "frontend": {
      "config": {
        "applicationName": "Agent IDE",
        "defaultTheme": "dark",
        "defaultIconTheme": "vs-seti"
      }
    },
    "backend": {
      "config": {
        "startupTimeout": -1
      }
    }
  },
  "dependencies": {
    "@agennext/agent-ide-core": "^0.1.0",
    "@theia/ai-anthropic": "1.73.0",
    "@theia/ai-chat": "1.73.0",
    "@theia/ai-chat-ui": "1.73.0",
    "@theia/ai-core": "1.73.0",
    "@theia/ai-core-ui": "1.73.0",
    "@theia/ai-google": "1.73.0",
    "@theia/ai-ide": "1.73.0",
    "@theia/ai-mcp": "1.73.0",
    "@theia/ai-mcp-ui": "1.73.0",
    "@theia/ai-ollama": "1.73.0",
    "@theia/ai-openai": "1.73.0",
    "@theia/ai-terminal": "1.73.0",
    "@theia/core": "1.73.0",
    "@theia/debug": "1.73.0",
    "@theia/editor": "1.73.0",
    "@theia/editor-preview": "1.73.0",
    "@theia/file-search": "1.73.0",
    "@theia/filesystem": "1.73.0",
    "@theia/markers": "1.73.0",
    "@theia/monaco": "1.73.0",
    "@theia/navigator": "1.73.0",
    "@theia/output": "1.73.0",
    "@theia/outline-view": "1.73.0",
    "@theia/preferences": "1.73.0",
    "@theia/scm": "1.73.0",
    "@theia/search-in-workspace": "1.73.0",
    "@theia/task": "1.73.0",
    "@theia/terminal": "1.73.0",
    "@theia/workspace": "1.73.0"
  },
  "devDependencies": {
    "@theia/cli": "1.73.0"
  }
}
