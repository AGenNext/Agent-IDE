{
  "name": "@agennext/agent-ide-backend",
  "version": "0.1.0",
  "description": "Agent IDE backend server — agent execution, tool proxy, WebSocket trace streaming",
  "license": "MIT",
  "main": "lib/server",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "start": "node lib/server.js",
    "dev": "ts-node src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agennext/agent-ide-types": "^0.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2"
  }
}
